// Main menu

int main(void)
{
	lcd_init(LCD_DISP_ON); // initialization of the LCD

	state_t state = IDLE; // initial state
	int16_t destination = 0; // initial case

	while (1) // loop
	{
		switch (state) // to determine the current state
		{
			case IDLE:
			destination = floor_choice(); // takes input as destination floor
			state = choose_direction(destination); // decides the direction of movement
			break;

			case GOINGUP:
			state = going_up(destination);
			break;

			case GOINGDOWN:
			state = going_down(destination);
			break;

			case DOOR_OPENING:
			state = door_opening();
			break;

			case DOOR_CLOSING:
			state = door_closing();
			break;

			case FAULT:
			state = IDLE;
			break;

			default:
			state = IDLE;
			break;
		}
	}
}
