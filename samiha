// Displaying the current floor
static void lcd_display_floor(int16_t floor)
{
	lcd_clrscr(); // clear the screen
	lcd_gotoxy(0, 0);
	lcd_puts("Current floor:");

	lcd_gotoxy(0, 1);

	if (floor >= 10) {
		lcd_putc((floor / 10) + '0');
		lcd_putc((floor % 10) + '0');
		} else {
		lcd_putc(floor + '0');
	}
}


// Going up function
static state_t going_up(int16_t destination_floor)
{
	set_as_output(&movement_led); // makes pin output
	set_gpio(&movement_led); // LED ON

	while (CURRENT_FLOOR < destination_floor) { // checks the floor

		CURRENT_FLOOR++; // increment floor number

		lcd_display_floor(CURRENT_FLOOR); // print current floor

		DELAY_ms(FLOOR_MOVING_SPEED_MS); // time to move for one floor
	}

	clear_gpio(&movement_led); // LED OFF

	return DOOR_OPENING; // door opens when destination floor is achieved
}


// Going down function


static state_t going_down(int16_t destination_floor)
{
	set_as_output(&movement_led); // makes pin output
	set_gpio(&movement_led); // LED ON

	while (CURRENT_FLOOR > destination_floor) { // checks the floor

		CURRENT_FLOOR--; // decrement the floor

		lcd_display_floor(CURRENT_FLOOR); // print the current floor

		DELAY_ms(FLOOR_MOVING_SPEED_MS); // time to move for one floor
	}

	clear_gpio(&movement_led); // LED OFF

	return DOOR_OPENING; // door opens when destination floor is achieved
}


// Door opening function

static state_t door_opening(void)
{
	set_as_output(&door_led); // makes pin output
	set_gpio(&door_led); // LED ON

	lcd_clrscr(); // clears the screen
	lcd_puts("Door open"); // print 

	DELAY_ms(DOOR_OPEN_DURATION_MS); // time to open the door

	clear_gpio(&door_led); // LED OFF

	return DOOR_CLOSING; // next step after the door opening
}




